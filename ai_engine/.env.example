# Python RAG Service — Environment Variables
# Copy this file to .env and fill in your values.

PORT=8000

# Gemini API (used for both embeddings and LLM — same key as Node.js backend)
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant Cloud
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Internal auth — must match INTERNAL_API_KEY in Node.js backend .env
INTERNAL_API_KEY=your_random_32_char_secret_here
